# TractorMate Backend Configuration
# Copy this file to .env and update with your values

# Secret key for JWT tokens (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here-generate-a-random-one

# JWT Algorithm
ALGORITHM=HS256

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=sqlite:///./tractormate.db

# Backup directory
BACKUP_DIR=/var/backups/tractormate

# Upload directory for receipts/photos
UPLOAD_DIR=./uploads

# Default admin password (used only on first run)
DEFAULT_ADMIN_PASSWORD=TractorMate@2024
